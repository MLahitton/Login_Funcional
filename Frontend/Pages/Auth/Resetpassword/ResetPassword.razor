@page "/reset-password"

@using Frontend.Models.Auth
@using Frontend.Services.Auth

@inject AuthApiService AuthService
@inject NavigationManager Navigation

<div class="forgot-container">
    <div class="forgot-card">
        <div class="logo">Nexo</div>
        <div class="icon-circle">Actualizar</div>
        <h2>Restablece tu contrasena</h2>
        <p>Escribe el codigo del correo y crea una nueva contrasena.</p>

        <EditForm Model="model" OnValidSubmit="HandleResetPassword">
            <DataAnnotationsValidator />

            <div class="form-group">
                <label>Correo electronico</label>
                <InputText class="form-control" @bind-Value="model.Email" />
                <ValidationMessage For="@(() => model.Email)" />
            </div>

            <div class="form-group">
                <label>Codigo</label>
                <InputText class="form-control" maxlength="6" @bind-Value="model.Code" />
                <ValidationMessage For="@(() => model.Code)" />
            </div>

            <div class="form-group">
                <label>Nueva contrasena</label>
                <InputText type="password" class="form-control" @bind-Value="model.NewPassword" />
                <ValidationMessage For="@(() => model.NewPassword)" />
            </div>

            <div class="form-group">
                <label>Confirmar nueva contrasena</label>
                <InputText type="password" class="form-control" @bind-Value="model.ConfirmPassword" />
                <ValidationMessage For="@(() => model.ConfirmPassword)" />
            </div>

            <button class="register-button" type="submit" disabled="@isLoading">
                @(isLoading ? "Actualizando..." : "Actualizar contrasena")
            </button>
        </EditForm>

        @if (!string.IsNullOrWhiteSpace(statusMessage))
        {
            <p style="margin-top: 15px;">@statusMessage</p>
        }

        <div class="back-login">
            <a href="/login">Volver al inicio de sesion</a>
        </div>
    </div>
</div>

@code {
    private readonly ResetPasswordRequest model = new();
    private string statusMessage = string.Empty;
    private bool isLoading;

    protected override void OnInitialized()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        model.Email = ReadQueryValue(uri.Query, "email");
    }

    private async Task HandleResetPassword()
    {
        isLoading = true;
        statusMessage = string.Empty;

        var response = await AuthService.ResetPassword(model);
        statusMessage = response.Message;
        isLoading = false;

        if (response.Success)
        {
            Navigation.NavigateTo("/login");
        }
    }

    private static string ReadQueryValue(string query, string key)
    {
        if (string.IsNullOrWhiteSpace(query))
        {
            return string.Empty;
        }

        var parts = query.TrimStart('?').Split('&', StringSplitOptions.RemoveEmptyEntries);

        foreach (var part in parts)
        {
            var tokens = part.Split('=', 2);
            if (tokens.Length != 2)
            {
                continue;
            }

            if (string.Equals(tokens[0], key, StringComparison.OrdinalIgnoreCase))
            {
                return Uri.UnescapeDataString(tokens[1]);
            }
        }

        return string.Empty;
    }
}
