@page "/forgot-password"

@using Frontend.Models.Auth
@using Frontend.Services.Auth

@inject AuthApiService AuthService
@inject NavigationManager Navigation

<div class="forgot-container">
    <div class="forgot-card">
        <div class="logo">Nexo</div>
        <div class="icon-circle">Recuperar</div>
        <h2>Olvidaste tu contrasena?</h2>
        <p>Ingresa tu correo y enviaremos un codigo de recuperacion.</p>

        <EditForm Model="model" OnValidSubmit="HandleForgotPassword">
            <DataAnnotationsValidator />

            <div class="form-group">
                <label>Correo electronico</label>
                <InputText class="form-control" @bind-Value="model.Email" />
                <ValidationMessage For="@(() => model.Email)" />
            </div>

            <button class="register-button" type="submit" disabled="@isLoading">
                @(isLoading ? "Enviando..." : "Enviar codigo")
            </button>
        </EditForm>

        @if (!string.IsNullOrWhiteSpace(statusMessage))
        {
            <p style="margin-top: 15px;">@statusMessage</p>
        }

        <div class="back-login">
            <a href="/login">Volver al inicio de sesion</a>
        </div>
    </div>
</div>

@code {
    private readonly ForgotPasswordRequest model = new();
    private string statusMessage = string.Empty;
    private bool isLoading;

    private async Task HandleForgotPassword()
    {
        isLoading = true;
        statusMessage = string.Empty;

        var response = await AuthService.ForgotPassword(model);
        statusMessage = response.Message;
        isLoading = false;

        if (response.Success)
        {
            var email = Uri.EscapeDataString(model.Email);
            Navigation.NavigateTo($"/reset-password?email={email}");
        }
    }
}
